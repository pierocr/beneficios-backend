{
  "name": "beneficios-cl",
  "version": "1.0.0",
  "description": "Backend para scraping de beneficios bancarios en Chile",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "scrape": "ts-node src/jobs/run-scraper.ts",
    "scrape:all": "ts-node src/jobs/run-all-scrapers.ts",
    "scrape:bancochile": "ts-node src/jobs/run-scraper.ts bancochile",
    "scrape:cencosudscotia": "ts-node src/jobs/run-scraper.ts cencosudscotia",
    "scrape:falabella": "ts-node src/jobs/run-scraper.ts falabella",
    "scrape:bci": "ts-node src/jobs/run-scraper.ts bci",
    "scrape:santander": "ts-node src/jobs/run-scraper.ts santander"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.103.2",
    "@types/pdf-parse": "^1.1.5",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.59.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.6.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2"
  }
}
